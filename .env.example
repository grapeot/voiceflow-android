# Copy to .env (gitignored) for local live WebSocket integration tests.
# NEVER commit real tokens. Rotate any key that was pasted into chat or logs.

AI_BUILDER_TOKEN=replace-with-your-real-token
# Alternate name accepted by scripts/tests:
# VOICEFLOW_AI_BUILDER_TOKEN=replace-with-your-real-token
AI_BUILDER_SPACE_ENDPOINT=https://space.ai-builders.com/backend

# Opt-in OpenCode live e2e test credentials (OpenCodeLiveSendTranscriptTest).
# Copy this file to .env (gitignored) and fill in real values. When these are
# absent the live instrumented test self-skips via assumeTrue.
# NOTE: an emulator reaches the host machine's localhost via 10.0.2.2, so prefer
# http://10.0.2.2:4096 here; the test also rewrites localhost/127.0.0.1 -> 10.0.2.2.
OPENCODE_BASE_URL=http://10.0.2.2:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=replace-with-your-real-password
